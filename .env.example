NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated account emails that may open /admin (all generated models).
# Must be set for the Convex deployment: Dashboard → Settings → Environment Variables,
# or `npx convex env set ADMIN_EMAILS "you@example.com,other@example.com"`.
ADMIN_EMAILS=

FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

MESHY_API_KEY=
MESHY_BASE_URL=https://api.meshy.ai
MESHY_MODEL=meshy-5
MESHY_USE_MOCK=false
# Preview mesh size (API defaults to huge meshes when remesh is off). Optional:
# MESHY_PREVIEW_MODEL_TYPE=lowpoly
# Or standard + remesh (default): should_remesh true, target_polycount 25000, topology triangle
# MESHY_PREVIEW_SHOULD_REMESH=true
# MESHY_PREVIEW_TARGET_POLYCOUNT=25000
# MESHY_PREVIEW_TOPOLOGY=triangle
# Max quality (large files): MESHY_PREVIEW_SHOULD_REMESH=false
# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=
